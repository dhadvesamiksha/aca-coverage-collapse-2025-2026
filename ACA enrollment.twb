      <aliases enabled='yes' />
      <column caption='National Drop %' datatype='real' name='[Calculation_1418106343075840]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([enrl_2026]) - SUM([enrl_2025])) / SUM([enrl_2025]) * 100' />
      </column>
      <column caption='States 95+ Dependency' datatype='integer' name='[Calculation_1418106343264257]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [aptc_rate_2025] &gt;= 95 THEN [state] END)' />
      </column>
      <column caption='Max Bronze Shift' datatype='real' name='[Calculation_1418106391838722]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MAX([bronze_shift])' />
      </column>
      <column caption='Max Food Stress' datatype='real' name='[Calculation_1418106394632195]' role='measure' type='quantitative'>
